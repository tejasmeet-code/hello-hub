# ── Discord Bot Credentials (Required) ──
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id

# ── Database Connection String (Required) ──
# Get this from your Supabase Project -> Settings -> Database -> Connection String (URI format)
# Must use postgresql:// scheme and include your database password!
DATABASE_URL=postgresql://postgres.your_supabase_project_id:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Logging & Webhooks (Optional/Recommended) ──
NODE_ENV=production
LOG_LEVEL=info
MESSAGE_LOGS=https://discord.com/api/webhooks/your_dm_log_webhook_here
DISCORD_WEBHOOK_URL_1=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_URL_3=https://discord.com/api/webhooks/...

# ── Admin & External Services (Optional) ──
DISCORD_OWNER_ID=1181221352393420856
GOOGLE_API_KEY=your_google_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Supabase API (Optional / For Client Integration) ──
SUPABASE_URL=https://your_supabase_project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
